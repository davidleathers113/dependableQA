---
import AppLayout from "../../layouts/AppLayout.astro";
---

<AppLayout title="Overview">
  <div class="space-y-6">
    <!-- Status Strip -->
    <div class="p-4 rounded-lg bg-neutral-900 border border-neutral-800 flex items-center justify-between">
      <div class="flex items-center space-x-2">
        <span class="w-2 h-2 rounded-full bg-green-500"></span>
        <span class="text-sm font-medium text-neutral-300">System Active</span>
      </div>
      <div class="text-sm text-neutral-500">
        Last import: <span class="text-neutral-300">2 hours ago</span>
      </div>
    </div>

    <!-- KPI Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {[
        { label: 'Account Balance', value: '$1,240.50', sub: 'Projected: 12 days left' },
        { label: 'Calls This Month', value: '4,821', sub: '+12% from last month' },
        { label: 'Minutes Processed', value: '18,402', sub: 'Avg 3.8m / call' },
        { label: 'Flag Rate', value: '4.2%', sub: '202 calls requiring review' },
      ].map(kpi => (
        <div class="p-6 rounded-xl bg-neutral-900 border border-neutral-800 space-y-2">
          <p class="text-sm font-medium text-neutral-500 uppercase tracking-wider">{kpi.label}</p>
          <p class="text-2xl font-bold text-white">{kpi.value}</p>
          <p class="text-xs text-neutral-400">{kpi.sub}</p>
        </div>
      ))}
    </div>

    <!-- Needs Attention -->
    <div class="space-y-4">
      <h3 class="text-lg font-semibold text-white">Needs Attention</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="p-4 rounded-lg bg-red-950/20 border border-red-900/50 flex items-start space-x-4">
          <div class="p-2 rounded-md bg-red-900/20 text-red-500">⚠️</div>
          <div>
            <p class="text-sm font-medium text-red-200">Low Balance Alert</p>
            <p class="text-xs text-red-400/80">Your balance is below the threshold of $500.00.</p>
          </div>
        </div>
        <div class="p-4 rounded-lg bg-amber-950/20 border border-amber-900/50 flex items-start space-x-4">
          <div class="p-2 rounded-md bg-amber-900/20 text-amber-500">🔌</div>
          <div>
            <p class="text-sm font-medium text-amber-200">Integration Degraded</p>
            <p class="text-xs text-amber-400/80">Ringba integration has returned 14 errors in the last hour.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</AppLayout>
