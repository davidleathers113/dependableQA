---
export const prerender = false;
import { getDefaultOrganizationId } from "../lib/app-data";
import { setActiveOrganizationId } from "../lib/auth/active-organization";
import AuthCard from "../components/auth/AuthCard.astro";
import AuthSidePanel from "../components/auth/AuthSidePanel.astro";
import LoginForm from "../components/auth/LoginForm";
import AuthLayout from "../layouts/AuthLayout.astro";

function normalizeLoginError(message: string) {
  const normalizedMessage = message.trim().toLowerCase();

  if (normalizedMessage.includes("invalid login credentials")) {
    return "We couldn’t match that email and password. Double-check both and try again.";
  }

  if (normalizedMessage.includes("email not confirmed")) {
    return "Confirm your email address from the link in your inbox, then try again.";
  }

  if (normalizedMessage.includes("rate limit")) {
    return "Too many sign-in attempts just now. Wait a moment, then try again.";
  }

  if (normalizedMessage.includes("network")) {
    return "We couldn’t reach the authentication service. Try again in a moment.";
  }

  return "We couldn’t log you in right now. Please try again.";
}

const { session } = Astro.locals;
const resetSuccess = Astro.url.searchParams.get("reset") === "success";

if (session) {
  const organizationId = await getDefaultOrganizationId(Astro.locals.supabase, session.user.id);
  if (organizationId) {
    setActiveOrganizationId(Astro.cookies, organizationId);
    return Astro.redirect("/app/overview");
  }

  return Astro.redirect("/onboarding");
}

let errorMessage = "";
let submittedEmail = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const email = String(formData.get("email") ?? "").trim();
  const password = String(formData.get("password") ?? "");
  submittedEmail = email;

  if (!email || !password) {
    errorMessage = "Email and password are required.";
  } else {
    const { error } = await Astro.locals.supabase.auth.signInWithPassword({
      email,
      password,
    });

    if (error) {
      errorMessage = normalizeLoginError(error.message);
    } else {
      const {
        data: { session: nextSession },
      } = await Astro.locals.supabase.auth.getSession();

      if (!nextSession) {
        errorMessage = "Signed in, but no session was returned. Try again.";
      } else {
        const organizationId = await getDefaultOrganizationId(Astro.locals.supabase, nextSession.user.id);
        if (organizationId) {
          setActiveOrganizationId(Astro.cookies, organizationId);
          return Astro.redirect("/app/overview");
        }

        return Astro.redirect("/onboarding");
      }
    }
  }
}
---

<AuthLayout
  title="Log in"
  description="Access your DependableQA workspace to review call quality, investigate flagged traffic, and manage your account."
>
  <AuthCard
    eyebrow="Secure workspace access"
    title="Log in to DependableQA"
    description="Access your workspace to review call quality, investigate flagged traffic, and manage your account."
  >
    {resetSuccess && (
      <div class="mb-5 rounded-2xl border border-emerald-500/20 bg-emerald-500/10 px-4 py-3 text-sm font-medium text-emerald-200">
        Your password has been updated. Log in with your new password to continue.
      </div>
    )}

    <LoginForm
      client:load
      action={Astro.url.pathname}
      initialEmail={submittedEmail}
      serverError={errorMessage}
    />
  </AuthCard>

  <AuthSidePanel
    slot="side-panel"
    eyebrow="Auditable Call QA"
    title="Review every decision with confidence."
    description="Track imports, inspect AI classifications, and stay in control of your operation with a workspace built for operational clarity."
    points={[
      "Track every import across teams and workflows.",
      "Audit every AI decision before it becomes a business risk.",
      "Reclaim control over call quality with a clear review trail.",
    ]}
  />
</AuthLayout>
