---
export const prerender = false;
import Hero from "../components/marketing/Hero.astro";
import Footer from "../components/marketing/Footer.astro";
import Navbar from "../components/marketing/Navbar.astro";
import MarketingLayout from "../layouts/MarketingLayout.astro";

const { session } = Astro.locals;

if (session) {
  return Astro.redirect("/app/overview");
}
---

<MarketingLayout
  title="Auditable Call QA Operations System"
  description="Track every import, audit every AI decision, and take back control of call quality."
>
  <Fragment slot="navbar">
    <Navbar />
  </Fragment>

  <Hero />

  <Fragment slot="footer">
    <Footer />
  </Fragment>
</MarketingLayout>
