---
export const prerender = false;
import AppLayout from "../../../layouts/AppLayout.astro";
import CallDetailPage from "../../../features/calls/CallDetailPage";
import { getCallDetail } from "../../../lib/app-data";
import { requireAppSession } from "../../../lib/auth/require-app-session";

const session = await requireAppSession(Astro);
const callId = Astro.params.callId;

if (!callId) {
  return Astro.redirect("/app/calls");
}

const initialData = await getCallDetail(Astro.locals.supabase, session.organization.id, callId);
---

<AppLayout title="Call Detail" session={session}>
  <CallDetailPage
    client:load
    organizationId={session.organization.id}
    callId={callId}
    initialData={initialData}
  />
</AppLayout>
