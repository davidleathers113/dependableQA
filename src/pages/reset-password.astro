---
export const prerender = false;
import AuthCard from "../components/auth/AuthCard.astro";
import AuthSidePanel from "../components/auth/AuthSidePanel.astro";
import ResetPasswordForm from "../components/auth/ResetPasswordForm";
import AuthLayout from "../layouts/AuthLayout.astro";

const { session } = Astro.locals;
---

<AuthLayout
  title="Set a new password"
  description="Verify your recovery link and create a new password for your DependableQA account."
>
  <AuthCard
    eyebrow="Recovery link"
    title={session ? "Update your password" : "Set a new password"}
    description="We’ll verify your reset link first, then you can choose a new password for your account."
  >
    <ResetPasswordForm client:load />
  </AuthCard>

  <AuthSidePanel
    slot="side-panel"
    eyebrow="Protected recovery"
    title="Reset access without leaving your audit posture behind."
    description="Recovery links are validated before any password change is allowed, so your team can restore access while keeping account controls intact."
    points={[
      "Validate the recovery link before collecting a new password.",
      "Clear sensitive URL tokens once the reset session is established.",
      "Return the user to a clean login flow after the password is updated.",
    ]}
  />
</AuthLayout>
