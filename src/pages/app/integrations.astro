---
export const prerender = false;
import AppLayout from '../../layouts/AppLayout.astro';
import IntegrationsPage from '../../features/integrations/IntegrationsPage';
import { getIntegrationsSummary } from '../../lib/app-data';
import { requireAppSession } from '../../lib/auth/require-app-session';
import { getAdminSupabase } from '../../lib/supabase/admin-client';
import { loadBillingContext } from '../../server/ai-pricing';

const session = await requireAppSession(Astro);
const env = typeof process !== "undefined" ? process.env : {};
const publicAppOrigin = (env.NETLIFY_SITE_URL || env.APP_URL || "").trim();
const initialData = await getIntegrationsSummary(Astro.locals.supabase, session.organization.id, {
  fallbackSecretConfigured: Boolean(env.INTEGRATION_INGEST_SHARED_SECRET),
  fallbackHeaderName: env.INTEGRATION_INGEST_SIGNATURE_HEADER,
  fallbackPrefix: env.INTEGRATION_INGEST_SIGNATURE_PREFIX,
});
// Per-minute wallet rate for the Ringba import cost estimate. Read via the
// org-scoped service-role client (org-filtered inside loadBillingContext) so the
// rate is reliable regardless of the caller's RLS read access. 0 = not metered.
const billingContext = await loadBillingContext(getAdminSupabase(), session.organization.id);
const perMinuteRateCents = billingContext?.perMinuteRateCents ?? 0;
---

<AppLayout title="Integrations" session={session}>
  <script is:inline define:vars={{ publicAppOrigin }}>
    if (typeof window !== "undefined" && publicAppOrigin) {
      window.__DEPENDABLEQA_PUBLIC_APP_ORIGIN__ = publicAppOrigin;
    }
  </script>
  <IntegrationsPage
    client:load
    organizationId={session.organization.id}
    currentUserRole={session.organization.role}
    initialData={initialData}
    perMinuteRateCents={perMinuteRateCents}
  />
</AppLayout>
