{
  "name": "dependableqa",
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check:env-example": "node scripts/check-env-example.mjs",
    "check:migrations": "node scripts/check-migrations.mjs",
    "ci:verify": "npm run check:env-example && npm run check:migrations && npm test && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:db": "vitest run --config vitest.db.config.ts",
    "e2e:seed": "node tests/e2e/seed.mjs",
    "test:e2e": "node tests/e2e/setup-env.mjs && playwright test",
    "ringba:smoke-recording": "node scripts/ringba-recording-smoke.mjs"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/netlify": "^6.1.0",
    "@astrojs/react": "^5.0.3",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.48.1",
    "@tailwindcss/vite": "^4.0.1",
    "@tanstack/react-query": "^5.97.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^5.15.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "luxon": "^3.7.2",
    "openai": "^6.34.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "stripe": "^22.0.1",
    "tailwind-merge": "^3.5.0",
    "typescript": "^5.6.3",
    "wavesurfer.js": "^7.12.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.16",
    "@types/luxon": "^3.7.1",
    "@types/pg": "^8.20.0",
    "pg": "^8.21.0",
    "tailwindcss": "^4.0.1",
    "vitest": "^4.1.4"
  }
}
