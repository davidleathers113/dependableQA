---
export const prerender = false;
import RootLayout from "../layouts/RootLayout.astro";

const { session } = Astro.locals;

if (session) {
  return Astro.redirect("/app/overview");
}
---

<RootLayout title="Welcome">
  <div class="flex flex-col items-center justify-center py-24 text-center space-y-8">
    <h1 class="text-6xl font-bold tracking-tight text-white">
      Auditable Call QA <br /> <span class="text-neutral-500">Operations System</span>
    </h1>
    <p class="max-w-2xl text-xl text-neutral-400">
      Stop guessing why calls were disqualified. Track every import, audit every AI decision, and reclaim control over your operations.
    </p>
    <div class="flex items-center space-x-4">
      <a href="/signup" class="px-8 py-3 rounded-md bg-white text-neutral-900 font-bold hover:bg-neutral-200 transition-colors">
        Get Started
      </a>
      <a href="/login" class="px-8 py-3 rounded-md bg-neutral-800 text-white font-bold hover:bg-neutral-700 transition-colors border border-neutral-700">
        Sign In
      </a>
    </div>
  </div>
</RootLayout>
