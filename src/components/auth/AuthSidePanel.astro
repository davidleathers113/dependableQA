---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  points: string[];
}

const { eyebrow, title, description, points } = Astro.props;
---

<aside class="relative overflow-hidden rounded-3xl border border-slate-800/70 bg-slate-900/45 p-8 shadow-[0_30px_80px_rgba(2,6,23,0.45)]">
  <div class="pointer-events-none absolute inset-y-0 right-0 w-56 bg-[radial-gradient(circle_at_right,rgba(16,185,129,0.18),transparent_70%)]"></div>

  <div class="relative flex min-h-[540px] flex-col justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-emerald-300/85">
        {eyebrow}
      </p>

      <h2 class="mt-6 max-w-md text-4xl font-semibold tracking-tight text-white">
        {title}
      </h2>

      <p class="mt-4 max-w-xl text-base leading-7 text-slate-400">
        {description}
      </p>
    </div>

    <ul class="mt-10 space-y-4">
      {points.map((point) => (
        <li class="flex items-start gap-3 rounded-2xl border border-slate-800/80 bg-slate-950/35 px-4 py-4 text-sm text-slate-300">
          <span class="mt-1 inline-flex h-2.5 w-2.5 rounded-full bg-emerald-300"></span>
          <span>{point}</span>
        </li>
      ))}
    </ul>
  </div>
</aside>
