---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<section class="relative overflow-hidden rounded-3xl border border-slate-800/80 bg-slate-900/70 p-6 shadow-[0_30px_80px_rgba(2,6,23,0.55)] backdrop-blur sm:p-8">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-32 bg-[radial-gradient(circle_at_top,rgba(16,185,129,0.12),transparent_72%)]"></div>

  <div class="relative">
    <div class="inline-flex items-center gap-3 text-sm font-semibold tracking-tight text-white">
      <img
        src="/brand/dependableqa-logo.png"
        alt="DependableQA logo"
        class="h-10 w-10 rounded-xl object-contain"
        loading="eager"
        decoding="async"
      />
      <span>DependableQA</span>
    </div>

    {eyebrow && (
      <p class="mt-8 text-xs font-semibold uppercase tracking-[0.24em] text-emerald-300/85">
        {eyebrow}
      </p>
    )}

    <h1 class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
      {title}
    </h1>

    <p class="mt-3 max-w-lg text-sm leading-6 text-slate-400 sm:text-base">
      {description}
    </p>

    <div class="mt-8">
      <slot />
    </div>
  </div>
</section>
