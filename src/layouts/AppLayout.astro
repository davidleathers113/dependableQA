---
import "../../src/styles/globals.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

const primaryNav = [
  { label: 'Overview', href: '/app/overview', icon: 'dashboard' },
  { label: 'Calls', href: '/app/calls', icon: 'phone' },
  { label: 'Imports', href: '/app/imports', icon: 'upload' },
  { label: 'Integrations', href: '/app/integrations', icon: 'link' },
  { label: 'Reports', href: '/app/reports', icon: 'chart' },
];

const secondaryNav = [
  { label: 'Billing', href: '/app/billing', icon: 'credit-card' },
  { label: 'Settings', href: '/app/settings/profile', icon: 'settings' },
  { label: 'Ask AI', href: '/app/ai', icon: 'sparkles' },
  { label: 'Updates', href: '/app/updates', icon: 'bell' },
];
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | DependableQA</title>
  </head>
  <body class="h-full antialiased bg-neutral-900 text-neutral-100 flex overflow-hidden">
    <!-- Sidebar -->
    <aside class="hidden md:flex md:w-64 md:flex-col border-r border-neutral-800 bg-neutral-900">
      <div class="flex flex-col flex-1 min-h-0">
        <div class="flex items-center h-16 px-6 border-b border-neutral-800">
          <span class="text-lg font-bold tracking-tight">DependableQA</span>
        </div>
        <div class="flex-1 overflow-y-auto">
          <nav class="flex-1 px-4 py-6 space-y-8">
            <!-- Primary Nav -->
            <div class="space-y-1">
              {primaryNav.map((item) => (
                <a
                  href={item.href}
                  class:list={[
                    "flex items-center px-3 py-2 text-sm font-medium rounded-md transition-colors",
                    currentPath.startsWith(item.href)
                      ? "bg-neutral-800 text-white"
                      : "text-neutral-400 hover:text-white hover:bg-neutral-800"
                  ]}
                >
                  <span class="ml-3">{item.label}</span>
                </a>
              ))}
            </div>

            <!-- Secondary Nav -->
            <div class="space-y-1">
              <h3 class="px-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">
                Support
              </h3>
              {secondaryNav.map((item) => (
                <a
                  href={item.href}
                  class:list={[
                    "flex items-center px-3 py-2 text-sm font-medium rounded-md transition-colors",
                    currentPath.startsWith(item.href)
                      ? "bg-neutral-800 text-white"
                      : "text-neutral-400 hover:text-white hover:bg-neutral-800"
                  ]}
                >
                  <span class="ml-3">{item.label}</span>
                </a>
              ))}
            </div>
          </nav>
        </div>
        <div class="p-4 border-t border-neutral-800">
          <!-- User Menu Placeholder -->
          <div class="flex items-center px-3 py-2">
            <div class="w-8 h-8 rounded-full bg-neutral-700"></div>
            <div class="ml-3 min-w-0 flex-1">
              <p class="text-sm font-medium text-white truncate">User Name</p>
            </div>
          </div>
        </div>
      </div>
    </aside>

    <!-- Main Content -->
    <div class="flex flex-col flex-1 min-w-0 overflow-hidden">
      <!-- Top Utility Bar -->
      <header class="h-16 flex items-center justify-between px-8 border-b border-neutral-800 bg-neutral-900">
        <h2 class="text-xl font-semibold text-white">{title}</h2>
        <div class="flex items-center space-x-4">
          <!-- Utility placeholders -->
          <div class="w-8 h-8 rounded-md bg-neutral-800 flex items-center justify-center">
            <span class="text-neutral-400">🔍</span>
          </div>
          <div class="w-8 h-8 rounded-md bg-neutral-800 flex items-center justify-center">
            <span class="text-neutral-400">🔔</span>
          </div>
        </div>
      </header>

      <!-- Page Canvas -->
      <main class="flex-1 overflow-y-auto p-8 bg-neutral-950">
        <div class="max-w-7xl mx-auto">
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>
