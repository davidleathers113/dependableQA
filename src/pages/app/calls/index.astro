---
export const prerender = false;
import AppLayout from '../../../layouts/AppLayout.astro';
import CallsPage from '../../../features/calls/CallsPage';
import { buildCallFilters, getCallsPageData } from '../../../lib/app-data';
import { requireAppSession } from '../../../lib/auth/require-app-session';

const session = await requireAppSession(Astro);
const initialData = await getCallsPageData(
  Astro.locals.supabase,
  session.organization.id,
  buildCallFilters(Astro.url.searchParams)
);
---

<AppLayout title="Calls" session={session}>
  <CallsPage
    client:load
    organizationId={session.organization.id}
    userId={session.user.id}
    initialData={initialData}
  />
</AppLayout>
