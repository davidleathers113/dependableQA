SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional fallback when using the Netlify Supabase integration defaults
# SUPABASE_DATABASE_URL=https://your-project.supabase.co

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
OPENAI_API_KEY=
OPENAI_WEBHOOK_SECRET=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe-diarize
OPENAI_ANALYSIS_MODEL=gpt-4.1-mini
OPENAI_ANALYSIS_FALLBACK_MODEL=gpt-4.1
OPENAI_ANALYSIS_PROMPT_VERSION=v3
OPENAI_ANALYSIS_SCHEMA_VERSION=v2
AI_DISPATCH_SHARED_SECRET=
AI_DISPATCH_BATCH_LIMIT=5

# Optional SSRF allowlist for recording fetch/preflight. Comma-separated domain
# suffixes; a host is allowed if it equals an entry or is a subdomain of it
# (e.g. "ringba.com,amazonaws.com"). Leave empty to disable the allowlist and
# rely only on the private-IP/DNS guards. Enforced on the initial host and every
# redirect hop.
RECORDING_HOST_ALLOWLIST=

APP_URL=http://localhost:4321
NETLIFY_SITE_URL=https://your-site.netlify.app

INTEGRATION_INGEST_SHARED_SECRET=
INTEGRATION_INGEST_SIGNATURE_HEADER=x-dependableqa-signature
INTEGRATION_INGEST_SIGNATURE_PREFIX=sha256=

DEFAULT_RECHARGE_THRESHOLD_CENTS=2000
DEFAULT_RECHARGE_AMOUNT_CENTS=5000
DEFAULT_PER_MINUTE_RATE_CENTS=2

APP_ENCRYPTION_KEY=
