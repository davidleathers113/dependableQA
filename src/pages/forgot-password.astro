---
export const prerender = false;
import AuthCard from "../components/auth/AuthCard.astro";
import AuthSidePanel from "../components/auth/AuthSidePanel.astro";
import { buildRecoveryRedirectUrl, normalizeResetRequestErrorMessage } from "../lib/auth/recovery";
import { getDefaultOrganizationId } from "../lib/app-data";
import { setActiveOrganizationId } from "../lib/auth/active-organization";
import AuthLayout from "../layouts/AuthLayout.astro";

const { session } = Astro.locals;

if (session) {
  const organizationId = await getDefaultOrganizationId(Astro.locals.supabase, session.user.id);
  if (organizationId) {
    setActiveOrganizationId(Astro.cookies, organizationId);
    return Astro.redirect("/app/overview");
  }

  return Astro.redirect("/onboarding");
}

let errorMessage = "";
let successMessage = "";
let submittedEmail = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const email = String(formData.get("email") ?? "").trim();
  submittedEmail = email;

  if (!email) {
    errorMessage = "Email is required.";
  } else {
    const redirectTo = buildRecoveryRedirectUrl(Astro.url);
    const { error } = await Astro.locals.supabase.auth.resetPasswordForEmail(email, {
      redirectTo,
    });

    if (error) {
      errorMessage = normalizeResetRequestErrorMessage(error.message);
    } else {
      successMessage =
        "If an account exists for that email, we’ve sent a password reset link.";
    }
  }
}
---

<AuthLayout
  title="Forgot password"
  description="Request a secure password reset link for your DependableQA workspace."
>
  <AuthCard
    eyebrow="Password recovery"
    title="Reset your password"
    description="Enter the email tied to your workspace and we’ll send a secure link to create a new password."
  >
    <form method="POST" class="space-y-5">
      {errorMessage && (
        <div class="rounded-2xl border border-rose-500/25 bg-rose-500/10 px-4 py-3 text-sm font-medium text-rose-100">
          {errorMessage}
        </div>
      )}

      {successMessage && (
        <div class="rounded-2xl border border-emerald-500/20 bg-emerald-500/10 px-4 py-3 text-sm font-medium text-emerald-200">
          {successMessage}
        </div>
      )}

      <div class="space-y-2">
        <label for="email" class="text-sm font-medium text-slate-200">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          inputmode="email"
          autocomplete="email"
          autocapitalize="none"
          autocorrect="off"
          placeholder="you@company.com"
          required
          value={submittedEmail}
          class="flex h-12 w-full rounded-xl border border-slate-800 bg-slate-950/80 px-4 py-3 text-sm text-slate-100 placeholder:text-slate-500 focus:border-emerald-300/60 focus:outline-none focus:ring-2 focus:ring-emerald-300/20"
        />
        <p class="text-sm text-slate-500">
          We’ll send a recovery link to this address if it belongs to a DependableQA account.
        </p>
      </div>

      <button
        type="submit"
        class="inline-flex min-h-12 w-full items-center justify-center rounded-xl bg-white px-5 py-3 text-sm font-semibold text-slate-950 transition-colors hover:bg-slate-200 focus:outline-none focus:ring-2 focus:ring-emerald-300/40 focus:ring-offset-2 focus:ring-offset-slate-900"
      >
        Send reset link
      </button>

      <p class="text-center text-sm text-slate-400">
        Remembered your password? <a href="/login" class="font-medium text-white hover:text-emerald-300">Log in</a>
      </p>
    </form>
  </AuthCard>

  <AuthSidePanel
    slot="side-panel"
    eyebrow="Secure account recovery"
    title="Get back into your workspace without losing the audit trail."
    description="Recovery links are time-bound and tied to your account so teams can regain access without bypassing your normal security controls."
    points={[
      "Recover access without exposing whether an account exists.",
      "Use a one-time recovery link tied to your workspace email.",
      "Return to reviewing imports, flags, and QA decisions quickly.",
    ]}
  />
</AuthLayout>
