---
export const prerender = false;
import AppLayout from '../../../layouts/AppLayout.astro';
import ApiSettingsPage from '../../../features/settings/ApiSettingsPage';
import { getApiKeysData } from '../../../lib/app-data';
import { requireAppSession } from '../../../lib/auth/require-app-session';

const session = await requireAppSession(Astro);
const initialData = await getApiKeysData(Astro.locals.supabase, session.organization.id);
---

<AppLayout title="API Settings" session={session}>
  <ApiSettingsPage
    client:load
    organizationId={session.organization.id}
    currentUserRole={session.organization.role}
    initialData={initialData}
  />
</AppLayout>
