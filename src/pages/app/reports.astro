---
export const prerender = false;
import AppLayout from '../../layouts/AppLayout.astro';
import ReportsPage from '../../features/reports/ReportsPage';
import { getReportsSummary } from '../../lib/app-data';
import { requireAppSession } from '../../lib/auth/require-app-session';

const session = await requireAppSession(Astro);
const initialData = await getReportsSummary(Astro.locals.supabase, session.organization.id);
---

<AppLayout title="Reports" session={session}>
  <ReportsPage client:load organizationId={session.organization.id} initialData={initialData} />
</AppLayout>
