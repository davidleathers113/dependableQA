---
export const prerender = false;
import { getDefaultOrganizationId } from "../lib/app-data";
import { setActiveOrganizationId } from "../lib/auth/active-organization";
import AuthCard from "../components/auth/AuthCard.astro";
import AuthLayout from "../layouts/AuthLayout.astro";

const { session } = Astro.locals;

if (session) {
  const organizationId = await getDefaultOrganizationId(Astro.locals.supabase, session.user.id);
  if (organizationId) {
    setActiveOrganizationId(Astro.cookies, organizationId);
    return Astro.redirect("/app/overview");
  }

  return Astro.redirect("/onboarding");
}

let errorMessage = "";
let successMessage = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const email = String(formData.get("email") ?? "").trim();
  const password = String(formData.get("password") ?? "");
  const firstName = String(formData.get("first_name") ?? "").trim();
  const lastName = String(formData.get("last_name") ?? "").trim();

  if (email && password && firstName && lastName) {
    const redirectUrl = new URL("/onboarding", Astro.url);
    const { data, error } = await Astro.locals.supabase.auth.signUp({
      email,
      password,
      options: {
        emailRedirectTo: redirectUrl.toString(),
        data: {
          first_name: firstName,
          last_name: lastName,
        },
      },
    });

    if (error) {
      errorMessage = error.message;
    } else if (data.session) {
      return Astro.redirect("/onboarding");
    } else {
      successMessage = "Account created. Check your email to confirm your address, then continue onboarding.";
    }
  } else {
    errorMessage = "First name, last name, email, and password are required.";
  }
}
---

<AuthLayout
  title="Sign up"
  description="Create your DependableQA account and start auditing call quality with a shared, secure workspace."
>
  <AuthCard
    eyebrow="Create your workspace"
    title="Create your DependableQA account"
    description="Set up your account to review call quality, monitor imports, and start onboarding your team."
  >
    <form method="POST" class="space-y-5">
      {errorMessage && (
        <div class="rounded-2xl border border-rose-500/25 bg-rose-500/10 px-4 py-3 text-sm font-medium text-rose-100">
          {errorMessage}
        </div>
      )}
      {successMessage && (
        <div class="rounded-2xl border border-emerald-500/20 bg-emerald-500/10 px-4 py-3 text-sm font-medium text-emerald-200">
          {successMessage}
        </div>
      )}
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="space-y-2">
          <label for="first_name" class="text-sm font-medium text-slate-200">First name</label>
          <input name="first_name" id="first_name" type="text" autocomplete="given-name" required class="flex h-12 w-full rounded-xl border border-slate-800 bg-slate-950/80 px-4 py-3 text-sm text-slate-100 placeholder:text-slate-500 focus:border-emerald-300/60 focus:outline-none focus:ring-2 focus:ring-emerald-300/20" />
        </div>
        <div class="space-y-2">
          <label for="last_name" class="text-sm font-medium text-slate-200">Last name</label>
          <input name="last_name" id="last_name" type="text" autocomplete="family-name" required class="flex h-12 w-full rounded-xl border border-slate-800 bg-slate-950/80 px-4 py-3 text-sm text-slate-100 placeholder:text-slate-500 focus:border-emerald-300/60 focus:outline-none focus:ring-2 focus:ring-emerald-300/20" />
        </div>
      </div>
      <div class="space-y-2">
        <label for="email" class="text-sm font-medium text-slate-200">Email</label>
        <input name="email" id="email" type="email" autocomplete="email" required placeholder="you@company.com" class="flex h-12 w-full rounded-xl border border-slate-800 bg-slate-950/80 px-4 py-3 text-sm text-slate-100 placeholder:text-slate-500 focus:border-emerald-300/60 focus:outline-none focus:ring-2 focus:ring-emerald-300/20" />
      </div>
      <div class="space-y-2">
        <label for="password" class="text-sm font-medium text-slate-200">Password</label>
        <input name="password" id="password" type="password" autocomplete="new-password" required class="flex h-12 w-full rounded-xl border border-slate-800 bg-slate-950/80 px-4 py-3 text-sm text-slate-100 placeholder:text-slate-500 focus:border-emerald-300/60 focus:outline-none focus:ring-2 focus:ring-emerald-300/20" />
      </div>
      <button type="submit" class="inline-flex min-h-12 w-full items-center justify-center rounded-xl bg-white px-5 py-3 text-sm font-semibold text-slate-950 transition-colors hover:bg-slate-200 focus:outline-none focus:ring-2 focus:ring-emerald-300/40 focus:ring-offset-2 focus:ring-offset-slate-900">
        Create account
      </button>
      <p class="text-center text-sm text-slate-400">
        Already have an account? <a href="/login" class="font-medium text-white hover:text-emerald-300">Log in</a>
      </p>
    </form>
  </AuthCard>
</AuthLayout>
